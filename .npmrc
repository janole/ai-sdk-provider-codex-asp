# Supply-chain cooldown: only resolve versions published more than 4 days ago, so
# a compromised release has time to be detected and yanked before we pull it in.
# Needs npm >= 11.10.0; older npm ignores this silently. Value is in days.
# Escape hatch for a hotfix: npm i --min-release-age 0 <pkg>@<version>
min-release-age=4
